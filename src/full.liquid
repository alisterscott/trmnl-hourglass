{%- comment -%}
  Both bulbs share the same geometry. The top sand height (h) from the pinch
  equals the empty gap height from the pinch downward into the bottom bulb.
  Therefore both sand surfaces always share the same xl/xr x-coordinates.
  h is the area-proportional height from the quadratic formula:
    10h + 130h²/185 = proportion_remaining × 25900
{%- endcomment -%}
{%- assign _top_key = proportion_remaining | times: 20 | round -%}
{%- assign _top_h = 0 -%}
{%- if    _top_key == 0  %}{%- assign _top_h = 0   -%}
{%- elsif _top_key == 1  %}{%- assign _top_h = 36  -%}
{%- elsif _top_key == 2  %}{%- assign _top_h = 54  -%}
{%- elsif _top_key == 3  %}{%- assign _top_h = 68  -%}
{%- elsif _top_key == 4  %}{%- assign _top_h = 79  -%}
{%- elsif _top_key == 5  %}{%- assign _top_h = 89  -%}
{%- elsif _top_key == 6  %}{%- assign _top_h = 99  -%}
{%- elsif _top_key == 7  %}{%- assign _top_h = 107 -%}
{%- elsif _top_key == 8  %}{%- assign _top_h = 115 -%}
{%- elsif _top_key == 9  %}{%- assign _top_h = 122 -%}
{%- elsif _top_key == 10 %}{%- assign _top_h = 129 -%}
{%- elsif _top_key == 11 %}{%- assign _top_h = 135 -%}
{%- elsif _top_key == 12 %}{%- assign _top_h = 141 -%}
{%- elsif _top_key == 13 %}{%- assign _top_h = 147 -%}
{%- elsif _top_key == 14 %}{%- assign _top_h = 153 -%}
{%- elsif _top_key == 15 %}{%- assign _top_h = 158 -%}
{%- elsif _top_key == 16 %}{%- assign _top_h = 163 -%}
{%- elsif _top_key == 17 %}{%- assign _top_h = 168 -%}
{%- elsif _top_key == 18 %}{%- assign _top_h = 173 -%}
{%- elsif _top_key == 19 %}{%- assign _top_h = 178 -%}
{%- elsif _top_key == 20 %}{%- assign _top_h = 185 -%}
{%- endif -%}
{%- assign _hw_n = _top_h | times: 130 | plus: 925 -%}
{%- assign _hw   = _hw_n | divided_by: 185 -%}
{%- assign _top_sand_y  = 210 | minus: _top_h -%}
{%- assign _top_sand_xl = 150 | minus: _hw -%}
{%- assign _top_sand_xr = 150 | plus:  _hw -%}
{%- assign _bot_sand_y  = 210 | plus:  _top_h -%}

<div class="layout">
  <div style="display:flex;justify-content:center;align-items:center;width:100%;height:100%;">
    <svg width="240" height="400" viewBox="0 0 300 430" xmlns="http://www.w3.org/2000/svg">
      <!-- Glass fill (white background for upper and lower bulbs) -->
      <polygon points="15,25 285,25 155,210 145,210" fill="white"/>
      <polygon points="145,210 155,210 285,395 15,395" fill="white"/>
      <!-- Top sand: fills from pinch upward, area-proportional to proportion_remaining -->
      <polygon points="{{ _top_sand_xl }},{{ _top_sand_y }} {{ _top_sand_xr }},{{ _top_sand_y }} 155,210 145,210" fill="black"/>
      <!-- Falling sand stream: thin line from pinch to top of bottom sand, only while sand remains -->
      {%- if _top_key > 0 %}
      <rect x="148" y="210" width="3" height="{{ _top_h }}" fill="black"/>
      {%- endif %}
      <!-- Bottom sand: fills from base upward, area-proportional to proportion_elapsed -->
      <polygon points="{{ _top_sand_xl }},{{ _bot_sand_y }} {{ _top_sand_xr }},{{ _bot_sand_y }} 285,395 15,395" fill="black"/>
      <!-- Glass outline (drawn on top so borders stay crisp) -->
      <polygon points="15,25 285,25 155,210 145,210" fill="none" stroke="black" stroke-width="4"/>
      <polygon points="145,210 155,210 285,395 15,395" fill="none" stroke="black" stroke-width="4"/>
      <!-- Top cap -->
      <rect x="8" y="5" width="284" height="22" fill="black" rx="6"/>
      <!-- Bottom cap -->
      <rect x="8" y="393" width="284" height="22" fill="black" rx="6"/>
    </svg>
  </div>
</div>
<div class="title_bar">
  <span class="title">Today</span>
  <span class="instance">{{ todays_date_time }}</span>
</div>